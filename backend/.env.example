# ========================
# EthioCal Backend Config
# ========================

# Supabase — get these from your project's Settings > API page
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase JWT secret — found in Settings > API > JWT Settings
# Used to verify access tokens from Supabase Auth
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Image upload
MAX_IMAGE_SIZE_MB=10
STORAGE_BUCKET=food-images

# AI food recognition (placeholder — replace with your actual provider)
AI_MODEL_API_URL=
AI_MODEL_API_KEY=